# Base URL of the NestJS API, including its global prefix (api/v1).
# Local dev with the Vite proxy: leave unset, requests to /api/v1/* are
# proxied to http://localhost:3000 automatically (see vite.config.ts).
# Separate-domain production deploy (Render frontend/backend as two
# services): set this to the deployed API's full URL.
VITE_API_URL=http://localhost:3000/api/v1
