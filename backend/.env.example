# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/assignments_hub?schema=public"

# JWT
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="8h"

# App
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed frontend origins in production, e.g.
# CORS_ORIGIN="https://app.assignmentshub.co.ke"
# Leave unset in development to allow all origins.
CORS_ORIGIN=

# Seed data (used by prisma/seed.ts)
SEED_PLATFORM_ADMIN_EMAIL="admin@assignmentshub.co.ke"
SEED_PLATFORM_ADMIN_PASSWORD="ChangeMe123!"

# IntaSend (payments) — get these from your IntaSend dashboard
# (Settings > API Keys). Without these, subscription checkout and the
# webhook that activates a school's subscription will not work.
#
# IMPORTANT: keys are environment-locked. Test keys start with
# "ISPubKey_test_" / "ISSecretKey_test_" and only work against the sandbox
# (INTASEND_TEST_MODE="true"). Live keys start with "ISPubKey_live_" /
# "ISSecretKey_live_" and only work with INTASEND_TEST_MODE="false".
# Mixing a test key with live mode (or vice versa) is exactly what causes
# IntaSend's `authentication_failed` / "Session expired" error — double
# check the key prefix matches INTASEND_TEST_MODE before assuming it's a
# code bug.
INTASEND_PUBLISHABLE_KEY=""
INTASEND_SECRET_KEY=""
# Must match the "challenge" string you set when registering the webhook
# URL on the IntaSend dashboard (Settings > Webhooks) — IntaSend echoes it
# back inside every webhook JSON body as `challenge`, it is NOT a header
# or an HMAC signing secret. Point the webhook at:
# POST {your-api-url}/api/v1/payment/webhook
INTASEND_WEBHOOK_SECRET=""
# "true" while testing against IntaSend's sandbox, "false" once you're
# taking real payments. Must match the key prefix above (test vs live).
INTASEND_TEST_MODE="true"

# Optional: used as `host` / `redirect_url` on IntaSend checkout requests.
# APP_URL is your site's own domain (shown to the customer during checkout).
# PAYMENT_REDIRECT_URL is where IntaSend sends the customer back after a
# successful payment, e.g. "https://app.assignmentshub.co.ke/school-admin-dashboard/index.html".
APP_URL=""
PAYMENT_REDIRECT_URL=""
