// Assignments Hub - CBC Kenya SaaS
// Multi-tenant schema. Every tenant-scoped table carries school_id and is
// filtered by TenantGuard in the API layer (see src/common/guards/tenant.guard.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLATFORM_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum PaymentMethod {
  INTASEND
  MPESA
  EQUITY_PAYBILL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  AWAITING_VERIFICATION
  CONFIRMED
  FAILED
  REJECTED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}

enum SubscriptionInterval {
  MONTHLY
  ANNUAL
}

enum AssignmentType {
  AUTO_MARKED
  TEACHER_MARKED
  PRACTICAL
}

enum LabType {
  SIMULATION
  PRACTICAL
}

enum LabStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
  ESSAY
  FILE_UPLOAD
  MATCHING
  ORDERING
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  GRADED
  RETURNED
}

enum SmsType {
  ASSIGNMENT_COMPLETED
  NEW_ASSIGNMENT
  BROADCAST
}

enum SmsStatus {
  SENT
  FAILED
}

// AI Assignment Generator provider router (see backend/src/ai): DeepSeek is
// primary, Claude is the fallback used when DeepSeek is out of balance,
// rate-limited, or unavailable. See AiUsageLog / AiProviderRouterService.
enum AiProvider {
  DEEPSEEK
  CLAUDE
}

enum AiUsageStatus {
  SUCCESS
  FAILED
}

enum CslSubmissionStatus {
  PENDING
  APPROVED
  NEEDS_REVISION
}

// Drives which per-student rate applies in the subscription pricing table
// (see backend/src/common/config/plans.ts) — Day School and Boarding School
// are priced differently at every tier. Self-declared by the school admin on
// their own school settings, defaulting to DAY.
enum SchoolType {
  DAY
  BOARDING
}

enum SchoolThemeTemplate {
  ACADEMIC_NAVY
  ROYAL_BLUE
  MODERN_TEAL
  EMERALD_EDUCATION
  MAROON_PROFESSIONAL
}

// How a student ended up with a given track selection — did they pick it
// themselves, or accept the recommendation engine's top suggestion.
enum SelectionSource {
  MANUAL
  RECOMMENDATION
}

// Broad, self-reported category used to route a student toward relevant
// institutions and support guidance. Deliberately not a clinical/diagnostic
// classification — see StudentSupportAssessment's doc comment.
enum DisabilityCategory {
  VISUAL_IMPAIRMENT
  HEARING_IMPAIRMENT
  PHYSICAL_DISABILITY
  INTELLECTUAL_DEVELOPMENTAL
  AUTISM_SPECTRUM
  MULTIPLE_DEAFBLIND
  OTHER_UNSURE
}

// Self-reported level of day-to-day support the student currently needs —
// used only to weight which institution TYPE (fully specialized vs.
// inclusive-mainstream-with-accommodations) is suggested first, never
// exposed as a label on the student.
enum SupportLevel {
  MILD_SOME_SUPPORT
  MODERATE_REGULAR_SUPPORT
  SIGNIFICANT_INTENSIVE_SUPPORT
}

// What kind of place SupportInstitution row is — controls how it's grouped
// and captioned in the results view.
enum InstitutionType {
  ASSESSMENT_CENTER
  SPECIAL_SCHOOL
  INCLUSIVE_MAINSTREAM
  VOCATIONAL_TRAINING
  SUPPORT_ORGANIZATION
}

model School {
  id                  Int                @id @default(autoincrement())
  name                String
  code                String             @unique // short code students use to log in, e.g. "GHSCH"
  logoUrl             String? // NOT @map'd — matches the original unmapped "logoUrl" column from the initial migration.
  address             String?
  phone               String?
  contactEmail        String?            @map("contact_email")
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  type                SchoolType         @default(DAY) @map("school_type")
  themeTemplate       SchoolThemeTemplate @default(ACADEMIC_NAVY) @map("theme_template")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  users               User[]
  assignments         Assignment[]
  subscriptions       Subscription[]
  auditLogs           AuditLog[]
  labSessions         LabSession[]
  smsLogs             SmsLog[]
  cslSubmissions      CslSubmission[]
  pathwaySelections   StudentPathwaySelection[]
  supportAssessments  StudentSupportAssessment[]
  aiUsageLogs         AiUsageLog[]
  invoices            Invoice[]
  paymentTransactions PaymentTransaction[]
  aiUsageLedgerEntries AIUsageLedger[]

  @@map("schools")
}

model User {
  id              Int       @id @default(autoincrement())
  schoolId        Int       @map("school_id")
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name            String
  role            Role

  // Staff credentials (Teacher / School Admin / Platform Admin)
  email           String?
  passwordHash    String?   @map("password_hash")

  // Student credentials
  admissionNumber String?   @map("admission_number")
  // Student's grade/class (e.g. "Grade 7"), used to scope which assignments
  // they see. Not applicable to staff roles.
  grade           String?
  // Parent/guardian phone number in international format (e.g.
  // "+254712345678"), used by SmsService to notify the parent when this
  // student completes an assignment or a new one is posted. Student-only.
  parentPhone     String?   @map("parent_phone")

  // Teacher-only metadata (credential allocation): subject specialty and
  // the class they're assigned to. Not applicable to other roles.
  subject         String?
  assignedClass   String?   @map("assigned_class")

  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  submissions     Submission[]
  auditLogs       AuditLog[]
  createdAssignments Assignment[] @relation("AssignmentCreatedBy")
  labSessions     LabSession[]
  createdLabs     Lab[]          @relation("LabCreatedBy")
  gradedSubmissions Submission[] @relation("SubmissionGradedBy")
  sentSmsLogs     SmsLog[]       @relation("SmsSentBy")
  smsLogsAboutMe  SmsLog[]       @relation("SmsAboutStudent")
  createdCslActivities CslActivity[]   @relation("CslActivityCreatedBy")
  cslSubmissions       CslSubmission[] @relation("CslSubmissionByStudent")
  reviewedCslSubmissions CslSubmission[] @relation("CslSubmissionReviewedBy")
  pathwaySelections    StudentPathwaySelection[]
  refreshTokens        RefreshToken[]
  supportAssessments   StudentSupportAssessment[]
  aiUsageLogs          AiUsageLog[]
  verifiedPayments     PaymentTransaction[] @relation("PaymentVerifiedBy")

  @@unique([schoolId, email])
  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@map("users")
}

// Opaque (non-JWT) refresh tokens, stored hashed so a DB leak alone can't be
// used to mint sessions. Paired with a short-lived JWT access token (see
// AuthService.issueTokenPair): the access token proves identity on every
// request without a DB hit, this table is only consulted on the infrequent
// POST /auth/refresh call, where it also gives us real revocation (logout,
// theft detection) that a stateless JWT can't provide on its own.
model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // SHA-256 hex digest of the actual token the client holds — never store
  // the plaintext token server-side.
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  // Set when this token was rotated out for a newer one (normal refresh
  // flow). If a request ever presents a token that has this set AND is
  // being reused (not the case that replaced it), that's a strong signal
  // of token theft — AuthService.refresh() responds by revoking every
  // token for the user.
  replacedByTokenHash String? @map("replaced_by_token_hash")
  createdByIp String?   @map("created_by_ip")
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Assignment {
  id            Int            @id @default(autoincrement())
  schoolId      Int            @map("school_id")
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  subject       String
  grade         String
  type          AssignmentType @default(TEACHER_MARKED)

  dueDate       DateTime?      @map("due_date")
  maxPoints     Int            @default(100) @map("max_points")
  isPublished   Boolean        @default(true) @map("is_published")
  // Optional future-dated release. The service layer, not a cron job, hides
  // unpublished/not-yet-due assignments from students — see
  // AssignmentsService.findAll.
  publishDate   DateTime?      @map("publish_date")

  // JSON array of { filename, url, size } — uploaded via POST /uploads and
  // referenced here, not stored as DB blobs.
  attachments   Json?
  // JSON array of plain URL strings (reference links, KEC content, etc.)
  resources     Json?

  // Exam-paper metadata, populated when an assignment is created via
  // POST /assignments/from-json (see AssignmentJsonDto). Both nullable so
  // assignments created via the older manual question-builder form (no
  // sections, no timer) are unaffected.
  timeAllowedMinutes Int?      @map("time_allowed_minutes")
  instructions       String?
  // The exact JSON payload originally uploaded (POST /assignments/from-json),
  // kept verbatim so a teacher can re-download/re-diff what they uploaded —
  // the relational rows below (Section/Question) are the source of truth for
  // everything the app actually reads and grades from.
  rawJson            Json?    @map("raw_json")

  createdById   Int?           @map("created_by_id")
  createdBy     User?          @relation("AssignmentCreatedBy", fields: [createdById], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  submissions   Submission[]
  questions     Question[]
  sections      Section[]
  rubric        Rubric?

  @@index([schoolId])
  @@map("assignments")
}

// A named group of questions within an exam paper (e.g. "Section A —
// Multiple Choice", "Section B — Structured Questions"). Optional: plain
// assignments created via the manual question-builder form have no
// sections, and their questions simply have sectionId = null.
model Section {
  id            Int        @id @default(autoincrement())
  assignmentId  Int        @map("assignment_id")
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  order         Int        @default(0)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  questions     Question[]

  @@index([assignmentId])
  @@map("sections")
}

model Question {
  id             Int          @id @default(autoincrement())
  assignmentId   Int          @map("assignment_id")
  assignment     Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  // Nullable — only set for questions uploaded as part of a JSON exam paper
  // with sections. A question with sectionId = null is either from the
  // manual question-builder form, or (rare) a JSON upload with no sections.
  sectionId      Int?         @map("section_id")
  section        Section?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  questionText   String       @map("question_text")
  questionType   QuestionType @default(ESSAY) @map("question_type")
  // JSON — shape depends on questionType:
  //  MULTIPLE_CHOICE: array of option strings, e.g. ["12", "14", "16", "18"]
  //  MATCHING:         { "left": [...], "right": [...] }
  //  ORDERING:         array of items in the (scrambled) display order
  //  everything else:  unused (null)
  options        Json?
  // Only used for auto-gradable types (MULTIPLE_CHOICE, TRUE_FALSE,
  // FILL_BLANK, MATCHING, ORDERING) — see SubmissionsService.AUTO_GRADABLE_TYPES.
  // MATCHING/ORDERING store a JSON-encoded string (object/array) here, same
  // as the student's answer — compared structurally, not as raw text. Never
  // returned to students — see AssignmentsService.stripAnswersForStudent.
  correctAnswer  String?      @map("correct_answer")
  points         Int          @default(10)
  order          Int          @default(0)
  hint           String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  answers        Answer[]

  @@index([assignmentId])
  @@index([sectionId])
  @@map("questions")
}

model Rubric {
  id            Int        @id @default(autoincrement())
  assignmentId  Int        @unique @map("assignment_id")
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  // JSON array of { criteria, points }
  criteria      Json
  totalPoints   Int        @map("total_points")

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("rubrics")
}

model Submission {
  id            Int              @id @default(autoincrement())
  assignmentId  Int              @map("assignment_id")
  assignment    Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId     Int              @map("student_id")
  student       User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Total awarded points. Kept as the pre-existing field name (rather than
  // renaming to totalPoints) so ReportsService's existing score-based
  // aggregates keep working unmodified.
  score         Int?
  status        SubmissionStatus @default(SUBMITTED)
  isLate        Boolean          @default(false) @map("is_late")
  feedback      String?
  // JSON array of { filename, url, size } for non-per-question uploads.
  attachments   Json?

  gradedById    Int?             @map("graded_by_id")
  gradedBy      User?            @relation("SubmissionGradedBy", fields: [gradedById], references: [id], onDelete: SetNull)
  gradedAt      DateTime?        @map("graded_at")

  // Autosave/draft support for the exam-taking UI: a student's in-progress
  // answers are saved here (via repeated PATCH-like POSTs with isDraft:
  // true, see SubmissionsService.create) with status DRAFT and no grading
  // applied yet. startedAt is set the first time a draft or final answer is
  // saved; timeSpentSeconds accumulates client-reported elapsed time and is
  // purely informational (never used for grading/lateness — isLate is still
  // computed from Assignment.dueDate).
  startedAt        DateTime?      @map("started_at")
  timeSpentSeconds Int?           @map("time_spent_seconds")

  completedAt   DateTime?        @map("completed_at")
  createdAt     DateTime         @default(now())

  answers       Answer[]

  @@index([assignmentId])
  @@index([studentId])
  @@map("submissions")
}

model Answer {
  id             Int        @id @default(autoincrement())
  submissionId   Int        @map("submission_id")
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  questionId     Int        @map("question_id")
  question       Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Raw student response — selected option text, true/false string, essay
  // text, or an uploaded file's URL (see POST /uploads) for FILE_UPLOAD.
  studentAnswer  String     @map("student_answer")
  isCorrect      Boolean?   @map("is_correct")
  pointsAwarded  Int?       @map("points_awarded")
  feedback       String?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@map("answers")
}

model Subscription {
  id        Int                @id @default(autoincrement())
  schoolId  Int                @map("school_id")
  school    School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // `plan` is now the auto-resolved tier name (Free/Starter/Standard/
  // Premium/Enterprise) at the time this subscription was created/paid —
  // see backend/src/common/config/plans.ts. It's no longer something a
  // client selects; PaymentService computes it from the school's live
  // student count + type. amountKES/studentCount/schoolType are a snapshot
  // of the numbers that produced that amount, kept for accurate revenue
  // reporting even as a school's enrollment changes later. All three are
  // nullable so older rows (created before this pricing model existed, e.g.
  // the seeded demo trial) remain valid.
  plan         String
  status       SubscriptionStatus @default(TRIAL)
  amountKES    Int?               @map("amount_kes")
  studentCount Int?               @map("student_count")
  schoolType   SchoolType?        @map("school_type")
  interval     SubscriptionInterval @default(MONTHLY)
  paymentMethod PaymentMethod?    @map("payment_method")
  startedAt    DateTime           @default(now()) @map("started_at")
  currentPeriodStart DateTime?    @map("current_period_start")
  currentPeriodEnd   DateTime?    @map("current_period_end")
  expiresAt    DateTime?          @map("expires_at")

  invoices            Invoice[]
  paymentTransactions PaymentTransaction[]

  @@index([schoolId])
  @@map("subscriptions")
}

model PaymentTransaction {
  id                 Int           @id @default(autoincrement())
  schoolId           Int           @map("school_id")
  school             School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscriptionId     Int?          @map("subscription_id")
  subscription       Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoiceId          Int?          @map("invoice_id")
  invoice            Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  providerReference  String?       @map("provider_reference")
  paymentReference   String?       @map("payment_reference")
  providerName       String?       @map("provider_name")
  amountKES          Int           @map("amount_kes")
  currency           String        @default("KES")
  payerName          String?       @map("payer_name")
  payerPhone         String?       @map("payer_phone")
  verifiedById       Int?          @map("verified_by_id")
  verifiedBy         User?         @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt         DateTime?     @map("verified_at")
  rejectedAt         DateTime?     @map("rejected_at")
  rejectionReason    String?       @map("rejection_reason")
  metadata           Json?
  initiatedAt        DateTime      @default(now()) @map("initiated_at")
  confirmedAt        DateTime?     @map("confirmed_at")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  webhookEvents      PaymentWebhookEvent[]

  @@index([schoolId])
  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([verifiedById])
  @@index([method, status])
  @@map("payment_transactions")
}

model Invoice {
  id                  Int                  @id @default(autoincrement())
  schoolId            Int                  @map("school_id")
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscriptionId      Int?                 @map("subscription_id")
  subscription        Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  invoiceNumber       String               @unique @map("invoice_number")
  status              InvoiceStatus        @default(DRAFT)
  interval            SubscriptionInterval @default(MONTHLY)
  paymentMethod       PaymentMethod?       @map("payment_method")
  amountKES           Int                  @map("amount_kes")
  currency            String               @default("KES")
  studentCountSnapshot Int?                @map("student_count_snapshot")
  schoolTypeSnapshot  SchoolType?          @map("school_type_snapshot")
  planSnapshot        String?              @map("plan_snapshot")
  issuedAt            DateTime?            @map("issued_at")
  dueAt               DateTime?            @map("due_at")
  paidAt              DateTime?            @map("paid_at")
  voidedAt            DateTime?            @map("voided_at")
  pdfPath             String?              @map("pdf_path")
  notes               String?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  paymentTransactions PaymentTransaction[]
  aiUsageLedgerEntries AIUsageLedger[]

  @@index([schoolId])
  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

model PaymentProviderConfig {
  id             Int           @id @default(autoincrement())
  method         PaymentMethod @unique
  displayName    String        @map("display_name")
  logoUrl        String?       @map("logo_url")
  instructions   String?
  isActive       Boolean       @default(true) @map("is_active")
  configuration  Json?         @map("configuration")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("payment_provider_configs")
}

model PaymentWebhookEvent {
  id                   Int                 @id @default(autoincrement())
  paymentTransactionId Int?                @map("payment_transaction_id")
  paymentTransaction   PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  method               PaymentMethod
  status               PaymentStatus?
  eventType            String              @map("event_type")
  providerReference    String?             @map("provider_reference")
  payload              Json
  receivedAt           DateTime            @default(now()) @map("received_at")
  processedAt          DateTime?           @map("processed_at")
  processingNotes      String?             @map("processing_notes")

  @@index([paymentTransactionId])
  @@index([method, eventType])
  @@map("payment_webhook_events")
}

model AIUsageLedger {
  id                  Int           @id @default(autoincrement())
  schoolId            Int           @map("school_id")
  school              School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceId           Int?          @map("invoice_id")
  invoice             Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  billingPeriodStart  DateTime      @map("billing_period_start")
  billingPeriodEnd    DateTime      @map("billing_period_end")
  provider            AiProvider?
  model               String?
  promptTokens        Int           @default(0) @map("prompt_tokens")
  completionTokens    Int           @default(0) @map("completion_tokens")
  totalTokens         Int           @default(0) @map("total_tokens")
  amountKES           Int           @default(0) @map("amount_kes")
  currency            String        @default("KES")
  notes               String?
  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([schoolId])
  @@index([invoiceId])
  @@index([billingPeriodStart, billingPeriodEnd])
  @@map("ai_usage_ledger")
}

// STEM Labs foundation (per backend/modules/stem_labs.md)
model LabSession {
  id            Int       @id @default(autoincrement())
  schoolId      Int       @map("school_id")
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId     Int       @map("student_id")
  student       User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  labKey        String    @map("lab_key") // identifies the simulation/experiment
  competency    String? // CBC competency mapping
  completedAt   DateTime? @map("completed_at")

  // Post-simulation knowledge-check quiz results (see LabQuestion). Both
  // null if the lab had no quiz questions at the time it was completed, or
  // the student hasn't taken the quiz yet — see LabSessionsService.create.
  // Reflected on the student's report card (ReportsService.studentReportCard).
  score         Int?
  maxScore      Int?      @map("max_score")
  // JSON array of { questionId, answer, isCorrect, pointsAwarded } — kept as
  // JSON rather than a relational table since lab quizzes are short and
  // never teacher-graded, unlike assignment submissions.
  answers       Json?
  quizCompletedAt DateTime? @map("quiz_completed_at")
  reflectionAnswers Json?    @map("reflection_answers")
  stepProgress      Json?    @map("step_progress")
  completionSummary Json?    @map("completion_summary")
  timeSpentSeconds  Int?     @map("time_spent_seconds")

  createdAt     DateTime  @default(now())

  @@index([schoolId])
  @@index([studentId])
  @@map("lab_sessions")
}

// Platform-wide catalog of virtual labs / practicals, managed by
// PLATFORM_ADMIN. `key` is what LabSession.labKey refers to when a student
// completes one (loose reference, not a DB foreign key, so existing
// LabSession rows referencing a key that predates the catalog still work).
model Lab {
  id            Int       @id @default(autoincrement())
  key           String    @unique
  title         String
  categoryId    Int?      @map("category_id")
  category      StemCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stemSubjectId Int?      @map("stem_subject_id")
  stemSubject   StemSubject? @relation(fields: [stemSubjectId], references: [id], onDelete: SetNull)
  subject       String
  // Student's grade/class level this lab targets (e.g. "Grade 7"), matching
  // User.grade / Assignment.grade — students only see labs for their own
  // grade (see LabsService.findAll), same rule as assignments.
  grade         String
  // Narrower classification within `subject`, e.g. "Cell Biology" under
  // subject "Biology" — used for catalog filtering/grouping in the UI.
  topicArea     String?   @map("topic_area")
  // Senior School pathway grouping (e.g. "Pure Sciences", "Applied Sciences
  // - Agriculture", "Technical Studies"). Null for Junior School labs, which
  // aren't organized by pathway.
  pathway       String?
  topic         String?
  competency    String?
  // Human-readable description of the lab shown in the catalog (what the
  // student will watch/do).
  description   String?
  // Expected video length in minutes. Drives the frontend's watch-timer:
  // the "Continue to Quiz" button stays disabled for roughly this long
  // after the video starts, so a student can't skip straight to the quiz
  // without at least watching through (see frontend/stem-labs/index.html).
  durationMinutes Int?    @map("duration_minutes")
  type          LabType   @default(SIMULATION)
  status        LabStatus @default(PUBLISHED)
  // A YouTube video URL (embed or watch link — the frontend normalizes it)
  // the student watches before taking the quiz. Null for labs that haven't
  // had real content added yet.
  resourceUrl   String?   @map("resource_url")
  introVideoUrl String?   @map("intro_video_url")
  animationUrl  String?   @map("animation_url")
  voiceAudioUrl String?   @map("voice_audio_url")
  isPublished   Boolean   @default(true) @map("is_published")

  // Ordered list of narration lines the frontend's female text-to-speech
  // voice-over reads aloud: an intro before the video plays, and an outro
  // once the quiz is submitted. Null/empty for labs without bespoke
  // narration yet — the frontend falls back to a generic line built from
  // `title`/`description`.
  guidanceSteps Json?     @map("guidance_steps")

  createdById   Int?      @map("created_by_id")
  createdBy     User?     @relation("LabCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  questions     LabQuestion[]
  media         LabMedia[]
  steps         LabStep[]
  reflectionPrompts LabReflectionPrompt[]
  completionReportTemplate LabCompletionReportTemplate?

  @@index([categoryId])
  @@index([stemSubjectId])
  @@index([grade])
  @@map("labs")
}

model StemCategory {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String   @unique
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subjects    StemSubject[]
  labs        Lab[]

  @@map("stem_categories")
}

model StemSubject {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  category    StemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  key         String   @unique
  name        String   @unique
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  labs        Lab[]

  @@index([categoryId])
  @@map("stem_subjects")
}

model LabMedia {
  id          Int      @id @default(autoincrement())
  labId       Int      @map("lab_id")
  lab         Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  type        String
  title       String?
  caption     String?
  url         String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([labId])
  @@map("lab_media")
}

model LabStep {
  id              Int      @id @default(autoincrement())
  labId           Int      @map("lab_id")
  lab             Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  title           String
  instruction     String
  mediaUrl        String?  @map("media_url")
  interactionType String?  @map("interaction_type")
  expectedOutcome String?  @map("expected_outcome")
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([labId])
  @@map("lab_steps")
}

model LabReflectionPrompt {
  id        Int      @id @default(autoincrement())
  labId     Int      @map("lab_id")
  lab       Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  prompt    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
  @@map("lab_reflection_prompts")
}

model LabCompletionReportTemplate {
  id           Int      @id @default(autoincrement())
  labId        Int      @unique @map("lab_id")
  lab          Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  title        String?
  summary      String?
  outcomesJson Json?    @map("outcomes_json")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("lab_completion_report_templates")
}

// Knowledge/competency check shown after a student finishes a lab's
// simulation. Deliberately mirrors Assignment's Question model (same
// QuestionType enum, same auto-grading rule: MULTIPLE_CHOICE/TRUE_FALSE/
// FILL_BLANK are scored server-side against `correctAnswer`; other types
// are left ungraded for now since there's no teacher-marking flow for lab
// quizzes yet).
model LabQuestion {
  id            Int          @id @default(autoincrement())
  labId         Int          @map("lab_id")
  lab           Lab          @relation(fields: [labId], references: [id], onDelete: Cascade)

  questionText  String       @map("question_text")
  questionType  QuestionType @default(MULTIPLE_CHOICE) @map("question_type")
  options       Json?
  // Never returned to students — see LabsService.stripAnswersForStudent.
  correctAnswer String?      @map("correct_answer")
  points        Int          @default(10)
  order         Int          @default(0)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([labId])
  @@map("lab_questions")
}

// Community Service Learning (CSL) — platform-wide catalog of grade-scoped
// activities, managed by PLATFORM_ADMIN (mirrors the Lab catalog pattern).
// `isRequired` activities are the ones a student's report card flags as
// outstanding until an APPROVED submission exists — see
// ReportsService.studentReportCard.
model CslActivity {
  id            Int       @id @default(autoincrement())
  key           String    @unique
  title         String
  description   String?
  // Student grade/class this activity targets, e.g. "Grade 7" — same
  // grade-scoping rule as Lab.grade.
  grade         String
  competency    String?
  isRequired    Boolean   @default(true) @map("is_required")
  targetHours   Int?      @map("target_hours")
  isPublished   Boolean   @default(true) @map("is_published")

  createdById   Int?      @map("created_by_id")
  createdBy     User?     @relation("CslActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  submissions   CslSubmission[]

  @@index([grade])
  @@map("csl_activities")
}

// A student's evidence (photo/video/document URL from POST
// /uploads/single) + reflection for one CslActivity, reviewed and scored by
// a teacher/school admin/platform admin ("tutor"). One row per
// (activity, student) — resubmitting after NEEDS_REVISION updates this same
// row rather than creating a new one (see CslSubmissionsService.create).
model CslSubmission {
  id            Int       @id @default(autoincrement())
  schoolId      Int       @map("school_id")
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  cslActivityId Int         @map("csl_activity_id")
  cslActivity   CslActivity @relation(fields: [cslActivityId], references: [id], onDelete: Cascade)

  studentId     Int       @map("student_id")
  student       User      @relation("CslSubmissionByStudent", fields: [studentId], references: [id], onDelete: Cascade)

  evidenceUrl   String?   @map("evidence_url")
  reflection    String?

  status        CslSubmissionStatus @default(PENDING)
  score         Int?
  maxScore      Int?      @map("max_score")
  feedback      String?

  reviewedById  Int?      @map("reviewed_by_id")
  reviewedBy    User?     @relation("CslSubmissionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt    DateTime? @map("reviewed_at")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([cslActivityId, studentId])
  @@index([schoolId])
  @@index([studentId])
  @@map("csl_submissions")
}

// Security_Model.md: audit logging of sensitive actions
model AuditLog {
  id        Int      @id @default(autoincrement())
  schoolId  Int?     @map("school_id")
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    String // e.g. "auth.login", "user.create", "assignment.update"
  resource  String? // e.g. "User:42"
  metadata  Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@map("audit_logs")
}

// SMS notifications: automatic (assignment completed / new assignment
// posted) and manual/mass (school admin or teacher broadcasts). One row per
// recipient phone number so a broadcast to 200 parents produces 200 rows
// with individually tracked delivery status — useful for retry/audit.
model SmsLog {
  id          Int       @id @default(autoincrement())
  schoolId    Int       @map("school_id")
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  type        SmsType
  toPhone     String    @map("to_phone")
  message     String
  status      SmsStatus @default(SENT)
  errorMessage String?  @map("error_message")

  // Optional linkage — set for ASSIGNMENT_COMPLETED / NEW_ASSIGNMENT so a
  // sent message can be traced back to the student/assignment involved.
  // No FK to Assignment (assignments are freely deletable; keeping the log
  // row around after that shouldn't require a schema-level cascade rule).
  studentId   Int?      @map("student_id")
  student     User?     @relation("SmsAboutStudent", fields: [studentId], references: [id], onDelete: SetNull)
  assignmentId Int?     @map("assignment_id")

  sentById    Int?      @map("sent_by_id")
  sentBy      User?     @relation("SmsSentBy", fields: [sentById], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())

  @@index([schoolId])
  @@index([studentId])
  @@map("sms_logs")
}

// AI Assignment Generator usage tracking (see backend/src/ai,
// AiProviderRouterService): one row per provider attempt, success or
// failure, across DeepSeek and Claude. Foundation for a future school-level
// AI generation limit, per-provider usage reports, token/cost tracking, and
// admin analytics — none of those are implemented yet, this model only
// records the data they'll need.
model AiUsageLog {
  id               Int           @id @default(autoincrement())
  schoolId         Int           @map("school_id")
  school           School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Nullable + SetNull (like AuditLog.userId) so the usage row — and any
  // future billing/report built on it — survives the user being removed.
  userId           Int?          @map("user_id")
  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  provider         AiProvider
  // Provider's model identifier, e.g. "deepseek-chat" or a dated Claude
  // snapshot. Nullable — not always known on a failed attempt.
  model            String?
  status           AiUsageStatus
  promptTokens     Int?          @map("prompt_tokens")
  completionTokens Int?          @map("completion_tokens")
  totalTokens      Int?          @map("total_tokens")
  errorMessage     String?       @map("error_message")
  createdAt        DateTime      @default(now())

  @@index([schoolId])
  @@index([userId])
  @@map("ai_usage_logs")
}

// ============================================================================
// Career Pathway Assessment (KICD Senior School Pathways, Grades 10-12)
// ----------------------------------------------------------------------------
// Pathway (STEM / Arts & Sports / Social Sciences) and Track (e.g. "Pure
// Sciences" under STEM) are a platform-wide catalog, managed by
// PLATFORM_ADMIN — mirrors the Lab/CslActivity catalog pattern elsewhere in
// this schema: global, not school-scoped, seeded once and rarely edited.
// StudentPathwaySelection is the per-student, per-school record, mirroring
// CslSubmission.
// ============================================================================

// One of the 3 KICD Senior School pathways.
model Pathway {
  id          Int      @id @default(autoincrement())
  key         String   @unique // "stem" | "arts" | "social"
  name        String
  description String
  icon        String   // Font Awesome class, e.g. "fa-flask"
  colorHex    String   @default("#BBD125") @map("color_hex")
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tracks      Track[]

  @@map("pathways")
}

// One specialization within a Pathway (e.g. "Pure Sciences", "Fine Arts",
// "Business Studies"). Everything a student needs to evaluate this track —
// required subjects, careers, universities, skills — is stored as JSON here,
// the same way Assignment.attachments/Question.options are elsewhere in this
// schema: it's reference content read as a whole and never filtered by its
// individual sub-fields, so typed JSON columns are simpler and far faster to
// extend (add a career, add a university) than a web of junction tables.
// Shapes (all populated by prisma/seed-pathways-data.ts):
//   requiredSubjects:  [{ subject: string, minGrade: string }]
//   careers:           [{ title, description?, salaryMinKES, salaryMaxKES }]
//   skills:            string[]
//   universitiesKenya: [{ name, programs: string[] }]
//   universitiesIntl:  [{ name, country, programs: string[] }]
//   nextSteps / extracurriculars / certifications / workExperience: string[]
model Track {
  id          Int     @id @default(autoincrement())
  pathwayId   Int     @map("pathway_id")
  pathway     Pathway @relation(fields: [pathwayId], references: [id], onDelete: Cascade)

  key         String  // "pure-sciences" — unique within its pathway
  name        String
  description String
  icon        String
  order       Int     @default(0)

  requiredSubjects Json    @map("required_subjects")
  // Overall KCSE mean grade requirement, e.g. "B+". Nullable — some tracks
  // (e.g. Sports) are less strictly grade-gated than the pure sciences.
  minMeanGrade     String? @map("min_mean_grade")

  careers           Json
  skills            Json
  jobOutlook        String? @map("job_outlook")
  jobGrowthRate     String? @map("job_growth_rate")

  universitiesKenya Json    @map("universities_kenya")
  universitiesIntl  Json    @map("universities_intl")
  degreeDurationYears Int?  @default(4) @map("degree_duration_years")

  // string[] of interest keywords (e.g. "science", "art", "sports") used
  // purely by PathwaysService's recommendation engine to score a student's
  // self-reported interests against each track — see
  // seed-pathways-data.ts for the fixed vocabulary.
  interestTags      Json?   @map("interest_tags")

  nextSteps         Json?   @map("next_steps")
  extracurriculars  Json?
  certifications    Json?
  workExperience    Json?   @map("work_experience")

  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  selections  StudentPathwaySelection[]

  @@unique([pathwayId, key])
  @@index([pathwayId])
  @@map("tracks")
}

// A student's track selection. History-preserving: choosing a different
// track inserts a NEW row (with isActive = true) and flips the student's
// previous row to isActive = false, rather than overwriting it in place —
// see PathwaysService.selectTrack. The row with isActive = true (at most one
// per student, enforced in the service layer via a transaction) is the
// student's current selection; every row together is their full history,
// satisfying "track their pathway selection history" without a separate
// audit table.
model StudentPathwaySelection {
  id        Int      @id @default(autoincrement())
  schoolId  Int      @map("school_id")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId Int      @map("student_id")
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  trackId   Int      @map("track_id")
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  isActive  Boolean         @default(true) @map("is_active")
  // Optional student-written reasoning ("why I chose this track"), shown to
  // teachers/parents on the report and editable any time.
  notes     String?
  source    SelectionSource @default(MANUAL)

  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([studentId])
  @@index([trackId])
  @@map("student_pathway_selections")
}

// Platform-wide catalog of real Kenyan institutions/organizations relevant
// to a student with a disability or additional support need: EARC
// assessment centres, special schools, inclusive mainstream schools known
// for good accommodations, vocational training providers, and ongoing
// support organizations (e.g. KISE, APDK). Mirrors the Pathway/Track
// pattern — global, PLATFORM_ADMIN-managed, seeded from a curated data
// file rather than relational per-field tables, since this is reference
// content that's always read as a whole.
model SupportInstitution {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  name        String
  type        InstitutionType
  // A given institution can serve more than one category (e.g. a school for
  // "physical and multiple disabilities") — stored as a JSON string array
  // of DisabilityCategory values rather than a native Postgres enum array,
  // consistent with the Json-columns-for-catalog-data convention already
  // used by Track's careers/universitiesKenya/etc.
  categories  Json
  county      String
  town        String?
  boardingType String?          @map("boarding_type") // "Day" | "Boarding" | "Day & Boarding"
  ageRange    String?           @map("age_range")
  description String
  servicesOffered Json?         @map("services_offered")
  contactPhone String?          @map("contact_phone")
  contactEmail String?          @map("contact_email")
  website     String?
  sourceNote  String?           @map("source_note") // brief attribution/last-verified note shown on the results view
  order       Int               @default(0)
  isPublished Boolean           @default(true) @map("is_published")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([type])
  @@map("support_institutions")
}

// A student's (or, realistically, a parent/guardian acting through the
// student account's) self-reported intake for support-needs guidance.
// Deliberately NOT a diagnosis or a replacement for a real assessment —
// this exists to (a) point every family toward their local Educational
// Assessment and Resource Centre (EARC) if they haven't already been
// assessed, and (b) surface a relevant, real starting shortlist of
// institutions and next steps in the meantime. History-preserving via
// isActive, same pattern as StudentPathwaySelection: a follow-up intake
// inserts a new row and flips the previous one's isActive to false rather
// than overwriting it, so a teacher/parent can see how things evolved.
model StudentSupportAssessment {
  id          Int                @id @default(autoincrement())
  schoolId    Int                @map("school_id")
  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId   Int                @map("student_id")
  student     User               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  category    DisabilityCategory
  supportLevel SupportLevel      @map("support_level")
  // Has the student/family already been through a formal EARC functional
  // assessment? Drives whether the results view leads with "go get
  // assessed first" or with the institution shortlist.
  hasFormalAssessment Boolean    @default(false) @map("has_formal_assessment")
  currentChallenges String?      @map("current_challenges")
  // Same free-text-tag shape as Track.interestTags, so results can lean on
  // shared vocabulary where relevant (e.g. a student interested in "art" or
  // "sports" gets that reflected in next-step suggestions too).
  interests   Json?
  notes       String?
  isActive    Boolean            @default(true) @map("is_active")

  createdAt   DateTime           @default(now())

  @@index([schoolId])
  @@index([studentId])
  @@map("student_support_assessments")
}
